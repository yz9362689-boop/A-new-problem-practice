#include <stdio.h>
 long long a[200005];
int n=0;
int main(){
  long long v;
while(scanf("%lld",&v)!=EOF){
  int i=n-1;
  while(i>=0&&a[i]>v){
    a[i+1]=a[i];
    i--;
    }
  a[i+1]=v;
 n++;
if(n%2==1){
printf("中位数：%lld",a[n/2]);
}
else{
long long sum = a[n/2-1]+a[n/2];
printf("中位数：%lld",sum / 2);
}
 }
return 0;
  }
