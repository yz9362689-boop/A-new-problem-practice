#include <iostream>
#include <algorithm>
#include <cmath>

using namespace std;

int main(){
int t;

if(cin>>t){
while(t--){
  int r;
  cin>>r;
int streets[500];
for(int i=0;i<r;i++){
cin>>streets[i];
}
  sort(streets,streets+r);
int total_distance=0;
int median = streets[r/2];
for(int i=0;i<r;i++){
total_distance+=abs(streets[i]-median);
}
cout<<total_distance<<endl;
}
  }
return 0;
}
